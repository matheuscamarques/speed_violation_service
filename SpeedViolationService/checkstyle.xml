<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="charset" value="UTF-8"/>

    <module name="TreeWalker">
        <!-- Sem var -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\bvar\s+\w+\s*="/>
            <property name="message" value="Não use 'var'. Declare o tipo explicitamente."/>
            <property name="ignoreComments" value="true"/>
        </module>

        <!-- Sem operador ternário -->
        <module name="AvoidInlineConditionals"/>

        <!-- Sem loops imperativos (for / while) -->
        <module name="RegexpSinglelineJava">
            <property name="format" value="\b(for|while)\s*\("/>
            <property name="message" value="Prefira streams a loops imperativos (for/while)."/>
            <property name="ignoreComments" value="true"/>
        </module>
    </module>
</module>
